# LLM (이후 단계에서 사용)
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=fabrix_lite

# Redis (3단계에서 사용, 콤마로 다중 노드 구분)
REDIS_URLS=redis://localhost:6379/0

# Langfuse Cloud (4단계에서 사용)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# 비용 가드 (4단계에서 사용)
TOKEN_LIMIT_PER_SESSION=100000
TOKEN_LIMIT_RESET_PERIOD=86400

# Advisory Lock 네임스페이스 (3단계에서 사용)
LOCK_NAMESPACE_TASK=1
LOCK_NAMESPACE_SCHEDULE=2

# OpenTelemetry → Langfuse Cloud (4단계에서 사용)
OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel
OTEL_EXPORTER_OTLP_HEADERS=x-langfuse-public-key=pk-lf-...,x-langfuse-secret-key=sk-lf-...
OTEL_ENABLED=true
